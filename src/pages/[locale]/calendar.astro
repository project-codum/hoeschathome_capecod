---
import { defaultLocale, locales, type Locale } from "../../i18n";
import CalendarTemplate from "../../pages-templates/Calendar.astro";

export const getStaticPaths = () =>
  locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));

const currentLocale = (Astro.params.locale ?? defaultLocale) as Locale;
---

<CalendarTemplate currentLocale={currentLocale} />
