---
import curveDivider from '../assets/decorative-elements/curve-divider.svg';
import { defaultLocale, getStrings, type Locale } from '../i18n';

const currentLocale = (Astro.currentLocale ?? defaultLocale) as Locale;
const content = getStrings(currentLocale).home;
const year = new Date().getFullYear();
---

<footer class="mt-auto bg-[var(--color-ocean)] text-white">
  <div class="-mb-px w-full bg-[var(--color-shell)] leading-none">
    <img
      src={curveDivider.src}
      alt=""
      aria-hidden="true"
      class="block h-auto w-full"
      loading="lazy"
    />
  </div>
  <div class="-mt-px py-10">
    <div class="container-responsive space-y-6 text-center text-sm">
    <div class="space-y-3">
      <p class="text-base font-semibold text-slate-50">{content.footerTagline}</p>
      <p class="text-slate-100">
        {content.footerContactLabel}
        <a
          class="font-medium text-slate-50 underline-offset-4 transition hover:text-white hover:underline"
          href="mailto:simone@hoesch-family.de"
        >
          simone@hoesch-family.de
        </a>
      </p>
    </div>

    <div class="flex justify-center text-slate-100">
      <div class="flex items-center justify-center gap-4 text-sm font-semibold text-slate-50">
        <span>{content.footerImprintLabel}</span>
        <span>{content.footerPrivacyLabel}</span>
      </div>
    </div>

    <p class="text-xs text-slate-200">
      &copy; {year} Hoesch@Home Hyannis. {content.footerRightsLabel}
    </p>
    </div>
  </div>
</footer>
