---
import type { HomeContent } from '../../i18n';

interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const headingId = 'optional-heading';
---

<section
  id="section-optional"
  class="section-spacing bg-[var(--color-shell)] text-[var(--color-ink)]"
  aria-labelledby={headingId}
>
  <div class="container-responsive grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div class="space-y-5">
      <p class="section-eyebrow">{content.sectionOptionalLabel}</p>
      <h2 id={headingId} class="section-title">{content.sectionOptionalHeading}</h2>
      {content.sectionOptionalBody && (
        <p class="section-body">{content.sectionOptionalBody}</p>
      )}
      <ul class="grid gap-2 text-sm sm:grid-cols-2 sm:text-base lg:grid-cols-1">
        {content.sectionOptionalHighlights.map((item) => (
          <li class="flex items-start gap-2">
            <span class="amenities-dot mt-2 shrink-0 bg-current" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="space-y-5 rounded-3xl border border-[var(--color-border)] bg-white/70 p-6 shadow-sm">
      <h3 class="text-2xl font-semibold leading-tight text-[var(--color-ink)]">{content.sectionRetreatHeading}</h3>
      <p class="section-body">{content.sectionRetreatBody}</p>
      <ul class="grid gap-2 text-sm sm:grid-cols-2 sm:text-base">
        {content.sectionRetreatHighlights.map((item) => (
          <li class="flex items-start gap-2">
            <span class="amenities-dot mt-2 shrink-0 bg-current" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
