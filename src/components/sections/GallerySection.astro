---
import livingArea from '../../assets/photos/08-living-area.png';
import waterfrontDeck from '../../assets/photos/09-coastal-detail-vignette.png';
import poolTerrace from '../../assets/photos/03-pool-terrace.png';
import type { HomeContent } from '../../i18n';
import GalleryScroll from '../GalleryScroll';

interface Props {
  id: string;
  content: HomeContent;
}

const { id, content } = Astro.props;
const headingId = `${id}-heading`;
---

<section
  id={id}
  class="section-spacing"
  aria-labelledby={headingId}
  data-gallery-section
>
  <div class="container-responsive space-y-10">
    <div class="max-w-3xl space-y-4">
      <p class="section-eyebrow" data-gallery-intro>{content.sectionGalleryLabel}</p>
      <h2 id={headingId} class="section-title" data-gallery-intro>
        {content.sectionGalleryHeading}
      </h2>
      <p class="section-body" data-gallery-intro>{content.sectionGalleryBody}</p>
    </div>
    <div class="grid gap-4 md:grid-cols-[1.3fr_0.7fr]">
      <figure
        class="media-tile media-tile--tall"
        style={`--media-image: url(${livingArea.src});`}
        data-gallery-tile
      >
        <figcaption class="media-caption">{content.sectionGalleryCaptionOne}</figcaption>
      </figure>
      <div class="grid gap-4">
        <figure
          class="media-tile media-tile--short"
          style={`--media-image: url(${waterfrontDeck.src});`}
          data-gallery-tile
        >
          <figcaption class="media-caption">{content.sectionGalleryCaptionTwo}</figcaption>
        </figure>
        <figure
          class="media-tile media-tile--short"
          style={`--media-image: url(${poolTerrace.src});`}
          data-gallery-tile
        >
          <figcaption class="media-caption">{content.sectionGalleryCaptionThree}</figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>

<GalleryScroll client:load />
