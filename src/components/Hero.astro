---
import heroBackground from '../assets/hero-bg.png';
import houseIllustration from '../assets/house-illustration.png';
import type { HomeContent, Locale } from '../i18n';

interface Props {
  content: HomeContent;
  currentLocale: Locale;
}

const { content } = Astro.props;
const {
  heroEyebrow,
  heroHeadline,
  heroBody,
  heroFeatures,
  heroAlt,
} = content;
---

<section
  id="section-hero"
  class="hero-shell relative flex min-h-[calc(100svh-6rem)] flex-col justify-end overflow-hidden px-4 pt-16 text-[var(--color-ink)] sm:px-6 sm:pt-20 lg:min-h-[calc(100svh-7rem)] lg:px-8 lg:pt-24"
  style={`--hero-bg: url(${heroBackground.src});`}
>
  <div class="relative z-20 mx-auto w-full max-w-6xl text-center">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-4">
      {heroEyebrow && (
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#e5a58b] sm:text-sm">
          {heroEyebrow}
        </p>
      )}
      <h1 class="max-w-4xl text-4xl font-semibold leading-[1.05] tracking-normal text-[var(--color-ink)] sm:text-5xl lg:text-6xl">
        {heroHeadline}
      </h1>
      <div class="max-w-2xl space-y-3 text-base font-normal leading-relaxed text-[var(--color-ink-muted)] sm:text-lg">
        {heroBody.map((line) => (
          <p>{line}</p>
        ))}
      </div>
    </div>

    <div class="mt-8 flex w-full justify-center sm:mt-10 lg:mt-12">
      <img
        src={houseIllustration.src}
        width={houseIllustration.width}
        height={houseIllustration.height}
        alt={heroAlt}
        class="hero-illustration h-auto w-[min(150vw,59.5rem)] max-w-none object-bottom drop-shadow-[0_18px_22px_rgba(23,50,58,0.16)] sm:w-[min(126vw,68.25rem)] lg:w-[73.5rem]"
        loading="eager"
        data-hero-illustration
      />
    </div>
  </div>

  <div class="absolute inset-x-4 bottom-8 z-20 flex flex-wrap items-center justify-center gap-2.5 sm:bottom-10 sm:gap-3 lg:bottom-12">
    {heroFeatures.map((item) => (
      <span class="inline-flex min-h-10 items-center rounded-full border border-white/80 bg-white/80 px-4 py-2 text-sm font-semibold leading-tight text-[var(--color-ink)] shadow-sm shadow-[rgba(45,78,91,0.08)] backdrop-blur sm:px-5">
        {item}
      </span>
    ))}
  </div>
</section>

<style>
  .hero-shell {
    background-color: #fffcf0;
    background-image:
      linear-gradient(180deg, rgba(255, 252, 240, 0.3) 0%, rgba(255, 252, 240, 0) 54%),
      var(--hero-bg);
    background-position: center bottom;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .hero-illustration {
    transform: translateX(-5%);
    transform-origin: center bottom;
  }

  @media (max-width: 640px) {
    .hero-shell {
      background-size: auto 100%;
      background-position: center bottom;
    }
  }
</style>
